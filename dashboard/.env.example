# Dashboard env (server-side)
# IMPORTANT: Tokens must NOT be exposed to the browser. Do NOT prefix tokens with NEXT_PUBLIC_.
#
# DATA_MODE:
#   mock   -> uses lib/data/mockData.ts (no DB needed)
#   influx -> queries InfluxDB directly from Next.js server components
DATA_MODE=influx

NEXT_PUBLIC_ENV_NAME=local

# InfluxDB (VM1)
INFLUX_URL=http://192.168.56.107:8086     # <-- set to your VM1 IP
INFLUX_ORG=ECE496
INFLUX_BUCKET=capstone

# READ-capable token (needed for dashboard queries)
INFLUX_QUERY_TOKEN=PASTE_READ_TOKEN_HERE

# Measurement names (defaults match your pipeline)
INFLUX_MEASUREMENT=mqtt_sensor
ML_MEASUREMENT=ml_summary

# Should match ML pipeline experiment segmentation (minutes)
GAP_SPLIT_MIN=5
