# Dashboard configuration
# DATA_MODE options:
#   mock     = built-in mock dataset
#   demojson = reads ./demo-json (offline demo)
#   influx   = reads InfluxDB (LIVE mode; requires VPN + SSH tunnel)
DATA_MODE=demojson

# ML service (read-only). Dashboard calls this for ml_flag/anomaly_score.
ML_SERVICE_URL=http://127.0.0.1:8000

# InfluxDB LIVE mode (DATA_MODE=influx)
# Tunnel VM2 Influx to localhost first:
#   ssh -N -L 8086:127.0.0.1:8086 -p 3246 cenit@128.100.23.125
INFLUX_URL=http://127.0.0.1:8086
INFLUX_ORG=ECE496
INFLUX_BUCKET=capstone
INFLUX_MEASUREMENT=mqtt_sensor

# Server-side token for querying (NEVER commit real tokens to git)
INFLUX_QUERY_TOKEN=REPLACE_ME

# Optional: how to split experiments by time gaps
GAP_SPLIT_MIN=5

# Optional: max list entries to fetch ML for
ML_MAX_LIST=50

# Live rolling window settings (client-side)
NEXT_PUBLIC_LIVE_CHART_WINDOW_MINUTES=2
NEXT_PUBLIC_LIVE_SCORE_WINDOW_MINUTES=5
NEXT_PUBLIC_LIVE_CHART_REFRESH_SECONDS=60
NEXT_PUBLIC_LIVE_SCORE_REFRESH_SECONDS=120
NEXT_PUBLIC_LIVE_LIST_REFRESH_SECONDS=120

# ML service URL (server-side fetch) and client-side awareness
ML_SERVICE_URL=http://127.0.0.1:8000

# Debug (Python scripts respect LOG_LEVEL)
# LOG_LEVEL=DEBUG
