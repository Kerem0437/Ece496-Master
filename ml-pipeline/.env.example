# =========================
# MQTT (VM2 broker)
# =========================
MQTT_HOST=192.168.56.108
MQTT_PORT=1883
MQTT_TOPIC=demo/496/chat

# Toggle TLS to match your broker config.
# Your VM1 bridge uses TLS by default. If broker is plaintext, set MQTT_TLS=false
MQTT_TLS=true
CERT_DIR=~/certs

# HMAC must match VM1 mqtt_to_influx.py
MQTT_HMAC_KEY=CHANGE_ME_TO_SAME_AS_VM1

# =========================
# InfluxDB (VM1)
# =========================
INFLUX_URL=http://192.168.56.107:8086   # <-- set to VM1 IP (Influx listens on 8086)
INFLUX_ORG=ECE496
INFLUX_BUCKET=capstone
INFLUX_MEASUREMENT=mqtt_sensor

# Token with READ for querying raw sensor data
INFLUX_QUERY_TOKEN=PASTE_READ_TOKEN_HERE

# Token with WRITE for writing ml_summary (can be write-only)
INFLUX_WRITE_TOKEN=PASTE_WRITE_TOKEN_HERE

# =========================
# ML config
# =========================
ML_VERSION=lstm_v1.0.0
SEQ_LEN=60          # timesteps per sequence (after resampling)
RESAMPLE_RULE=1min  # pandas offset alias
GAP_SPLIT_MIN=5     # gap minutes that split experiments
MIN_POINTS=30       # below -> INSUFFICIENT_DATA

# Thresholds for flags (on 0-1 anomaly_score)
THRESH_NORMAL=0.30
THRESH_SUSPICIOUS=0.70
