# ML service configuration (read-only scoring; no DB writes)
# Start service: uvicorn server:app --host 127.0.0.1 --port 8000

LOG_LEVEL=INFO
ML_HOST=127.0.0.1
ML_PORT=8000

# Artifacts are saved to ml_service/artifacts by default.
# ARTIFACTS_DIR=./artifacts

# Sequence/window defaults used by the service (informational; code uses defaults)
# SEQ_LEN=60
# STRIDE=60
